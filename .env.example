# PostgreSQL connection string (Neon or any Postgres works)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Password to log into the admin dashboard at /admin
ADMIN_PASSWORD=change-me

# Secret used to sign the admin session cookie (any long random string)
SESSION_SECRET=change-me-too

# Public base URL of this app once deployed, used to build QR codes
# e.g. https://tap.tondomaine.com
BASE_URL=https://tap.example.com

# Port the app listens on internally (Traefik will route to this)
PORT=3000

# Google Places API (for tracking reviews and ratings)
# Get a key from: https://console.cloud.google.com/ (Enable Places API)
GOOGLE_PLACES_API_KEY=
