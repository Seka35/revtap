<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Print Sheet</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="wrap no-print">
  <div class="top-nav">
    <div class="links"><a href="/admin">← Back</a></div>
  </div>
  <div class="panel" style="display:flex; justify-content:space-between; align-items:center;">
    <div>
      <h1 style="margin:0;">Print Sheet</h1>
      <p class="sub" style="margin:5px 0 0;">Print these QR codes to stick them in your stock. (Use Ctrl+P or Cmd+P)</p>
    </div>
    <button class="btn" onclick="window.print()">Print Now</button>
  </div>
</div>

<div style="max-width:21cm; margin:0 auto; padding:2cm;" class="print-container">
  <div class="print-grid">
    <% items.forEach(item => { %>
      <div class="print-card">
        <div class="qr-google-frame" id="qr-container-<%= item.code %>" data-url="<%= item.qrUrl %>"></div>
        <div class="code"><%= item.code %></div>
      </div>
    <% }) %>
  </div>
</div>

<%- include('partials/bottom-nav', { navActive: 'print' }) %>

<script src="https://unpkg.com/qr-code-styling@1.5.0/lib/qr-code-styling.js"></script>
<script>
document.querySelectorAll('.qr-google-frame[data-url]').forEach(container => {
  const qrCode = new QRCodeStyling({
    width: 1000,
    height: 1000,
    data: container.getAttribute('data-url'),
    margin: 10,
    dotsOptions: { type: "rounded", color: "#000000" },
    cornersSquareOptions: { type: "extra-rounded", color: "#000000" },
    cornersDotOptions: { type: "dot", color: "#000000" },
    backgroundOptions: { color: "transparent" }
  });
  qrCode.append(container);
});
</script>

</body>
</html>
