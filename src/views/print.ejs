<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Print Sheet</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="wrap no-print">
  <div class="top-nav">
    <div class="links"><a href="/admin">← Back</a></div>
  </div>
  <div class="panel" style="display:flex; justify-content:space-between; align-items:center;">
    <div>
      <h1 style="margin:0;">Print Sheet</h1>
      <p class="sub" style="margin:5px 0 0;">Print these QR codes to stick them in your stock. (Use Ctrl+P or Cmd+P)</p>
    </div>
    <button class="btn" onclick="window.print()">Print Now</button>
  </div>
</div>

<div style="max-width:21cm; margin:0 auto; padding:2cm;" class="print-container">
  <div class="print-grid">
    <% items.forEach(item => { %>
      <div class="print-card">
        <img src="<%= item.qrDataUrl %>" alt="QR <%= item.code %>">
        <div class="code"><%= item.code %></div>
      </div>
    <% }) %>
  </div>
</div>

<%- include('partials/bottom-nav', { navActive: 'print' }) %>

</body>
</html>
