<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bulk Generate — NFC Review Tracker</title>
<link rel="stylesheet" href="/style.css">
</head>
<body>
<div class="wrap">
  <div class="top-nav">
    <div class="links"><a href="/admin">← Back</a></div>
  </div>

  <div class="panel">
    <div class="eyebrow"><span class="dot"></span>BULK</div>
    <h1>Generate Codes in Bulk</h1>
    <p class="sub">Creates inactive codes to stick on cards in advance. You can activate them later.</p>
    
    <% if (error) { %><div class="error"><%= error %></div><% } %>

    <form method="POST" action="/admin/bulk">
      <label for="prefix">Code Prefix</label>
      <input type="text" id="prefix" name="prefix" value="a" required placeholder="e.g., a">

      <label for="count">Quantity to generate (max 200)</label>
      <input type="number" id="count" name="count" value="10" min="1" max="200" required>

      <button class="btn" type="submit">Generate & Print</button>
    </form>
  </div>
</div>

<%- include('partials/bottom-nav', { navActive: 'bulk' }) %>

</body>
</html>
