<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard — <%= business_name || 'Client' %></title>
<link rel="stylesheet" href="/style.css">
<!-- Chart.js for graphs -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
<div class="wrap">
  <div class="top-nav" style="position: sticky; top: 0; background: rgba(20, 21, 26, 0.95); backdrop-filter: blur(10px); z-index: 100; margin-left: -20px; margin-right: -20px; padding: 16px 20px; border-bottom: 1px solid var(--line); margin-bottom: 24px; align-items: center;">
    <div style="flex: 1;">
      <div class="eyebrow" style="margin-bottom: 4px;"><span class="dot"></span>CLIENT PORTAL</div>
      <h1 style="font-size: 20px; margin: 0;"><%= business_name || 'Your Business' %></h1>
    </div>
    <div class="links"><a href="/client/<%= code %>/logout" class="btn secondary" style="padding: 6px 12px; font-size: 12px;">Logout</a></div>
  </div>

  <div class="filter-group">
    <a href="?filter=24h" class="btn <%= currentFilter === '24h' ? '' : 'secondary' %>">24h</a>
    <a href="?filter=yesterday" class="btn <%= currentFilter === 'yesterday' ? '' : 'secondary' %>">Yesterday</a>
    <a href="?filter=week" class="btn <%= currentFilter === 'week' ? '' : 'secondary' %>">This Week</a>
    <a href="?filter=all" class="btn <%= currentFilter === 'all' ? '' : 'secondary' %>">All Time</a>
  </div>

  <% if (reviewHistory && reviewHistory.length > 0) { 
       const latest = reviewHistory[reviewHistory.length - 1];
       const first = reviewHistory[0];
       const rating = parseFloat(latest.rating).toFixed(1);
       const reviewCount = latest.user_ratings_total;
       
       const reviewGrowth = reviewCount - first.user_ratings_total;
       const ratingGrowth = (latest.rating - first.rating).toFixed(1);
  %>
  <div class="panel" style="background: linear-gradient(145deg, rgba(232, 147, 92, 0.1), rgba(20, 21, 26, 0.8)); border-color: var(--copper); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
    <div>
      <h2 style="color: var(--copper-bright); margin-bottom: 4px; display: flex; align-items: center; gap: 8px;">
        Google Reviews
        <span style="font-size: 11px; padding: 2px 6px; background: var(--copper); color: #000; border-radius: 4px; font-weight: 600;">LIVE</span>
      </h2>
      <div style="font-size: 32px; font-weight: bold; color: white; display: flex; align-items: center; gap: 8px;">
        <%= rating %>
        <div class="stars-container">
          <div class="stars-fill" style="width: <%= (rating / 5) * 100 %>%"></div>
        </div>
      </div>
      <div style="color: var(--ink-dim); font-size: 13px;">Based on <%= reviewCount %> authentic reviews</div>
    </div>
    
    <% if (reviewGrowth > 0 || ratingGrowth > 0) { %>
    <div style="background: rgba(127,191,143,0.1); border: 1px solid var(--good); padding: 12px 16px; border-radius: 8px; flex: 1; min-width: 200px;">
      <div style="font-size: 13px; color: var(--good); margin-bottom: 4px;">🚀 Impact since activation</div>
      <div style="font-size: 15px; color: white;">
        <% if (reviewGrowth > 0) { %>+<b><%= reviewGrowth %></b> new reviews<% } %>
        <% if (ratingGrowth > 0 && reviewGrowth > 0) { %> & <% } %>
        <% if (ratingGrowth > 0) { %>rating went up by <b>+<%= ratingGrowth %></b><% } %>
      </div>
    </div>
    <% } %>
  </div>
  
  <% if (latestReviews && latestReviews.length > 0) { %>
  <div class="panel">
    <h2>Latest 5-Star Experiences</h2>
    <div style="display: flex; gap: 12px; overflow-x: auto; padding-bottom: 8px;">
      <% latestReviews.forEach(r => { %>
        <div style="min-width: 250px; max-width: 280px; background: rgba(255,255,255,0.02); border: 1px solid var(--line); border-radius: 8px; padding: 12px; flex-shrink: 0;">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
            <% if (r.profile_photo_url) { %>
              <img src="<%= r.profile_photo_url %>" alt="<%= r.author_name %>" style="width: 24px; height: 24px; border-radius: 50%;">
            <% } else { %>
              <div style="width: 24px; height: 24px; background: var(--copper); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #000; font-size: 10px; font-weight: bold;">
                <%= r.author_name ? r.author_name.charAt(0).toUpperCase() : '?' %>
              </div>
            <% } %>
            <div style="font-size: 12px; color: white; font-weight: 500;"><%= r.author_name %></div>
          </div>
          <div style="color: #FFD700; font-size: 12px; margin-bottom: 6px;">
            <% for(let i=0; i<r.rating; i++) { %>★<% } %>
          </div>
          <div style="font-size: 12px; color: var(--ink-dim); display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
            "<%= r.text %>"
          </div>
        </div>
      <% }) %>
    </div>
  </div>
  <% } %>
  <% } %>

  <div class="stats-grid three-cols">
    <div class="stat">
      <div class="num"><%= stats.total %></div>
      <div class="label">Total Scans (<%= currentFilterLabel %>)</div>
    </div>
    <div class="stat">
      <div class="num"><%= stats.nfc_count %></div>
      <div class="label">Via NFC (Tap)</div>
    </div>
    <div class="stat">
      <div class="num"><%= stats.qr_count %></div>
      <div class="label">Via QR code</div>
    </div>
  </div>

  <div class="panel">
    <h2>Scan Analytics</h2>
    <canvas id="scansChart" width="400" height="150"></canvas>
  </div>

  <div class="panel">
    <h2>Detailed Insights</h2>
    <div class="stats-grid" style="grid-template-columns: repeat(2, 1fr);">
      <div class="stat">
        <div class="label" style="margin-top:0; margin-bottom:8px;">Top OS</div>
        <% if (osStats && osStats.length > 0) { %>
          <% osStats.forEach(os => { %>
            <div style="display:flex; justify-content:space-between; font-size:13px; margin-bottom:4px;">
              <span><%= os.os_name %></span>
              <span style="color:var(--good); font-family:'JetBrains Mono',monospace;"><%= os.count %></span>
            </div>
          <% }) %>
        <% } else { %>
          <div style="font-size:13px; color:var(--ink-faint);">No data</div>
        <% } %>
      </div>
      <div class="stat">
        <div class="label" style="margin-top:0; margin-bottom:8px;">Top Languages</div>
        <% if (langStats && langStats.length > 0) { %>
          <% langStats.forEach(lang => { %>
            <div style="display:flex; justify-content:space-between; font-size:13px; margin-bottom:4px;">
              <span><%= lang.browser_lang %></span>
              <span style="color:var(--good); font-family:'JetBrains Mono',monospace;"><%= lang.count %></span>
            </div>
          <% }) %>
        <% } else { %>
          <div style="font-size:13px; color:var(--ink-faint);">No data</div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="panel">
    <h2>Hourly Heatmap</h2>
    <p class="sub" style="margin-bottom:12px;">Concentration of scans by day and hour</p>
    <div style="overflow-x:auto;">
      <table class="heatmap-table" style="min-width: 600px; border-collapse: separate; border-spacing: 2px;">
        <thead>
          <tr>
            <th style="width: 35px; border: none; background: transparent;"></th>
            <% for (let h = 0; h < 24; h++) { %>
              <th style="font-size: 9px; font-weight: normal; color: var(--ink-faint); border: none; background: transparent; text-align: center; padding: 2px;"><%= h %>h</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun']; %>
          <% for (let d = 0; d < 7; d++) { %>
          <tr>
            <td style="font-size: 11px; color: var(--ink-dim); border: none; background: transparent; text-align: right; padding-right: 6px;"><%= days[d] %></td>
            <% for (let h = 0; h < 24; h++) { %>
              <% 
                const count = heatmapData[d][h]; 
                const intensity = maxHeat > 0 ? (count / maxHeat) : 0;
                const bgColor = count > 0 ? `rgba(127, 191, 143, ${Math.max(0.15, intensity)})` : 'rgba(255,255,255,0.02)';
                const textColor = count > 0 ? (intensity > 0.6 ? '#14151a' : 'var(--good)') : 'transparent';
              %>
              <td style="background: <%- bgColor %>; border: none; text-align: center; font-size: 10px; font-weight: 600; color: <%- textColor %>; border-radius: 3px; height: 22px; cursor: default;" title="<%= days[d] %> <%= h %>h: <%= count %> scans">
                <%= count > 0 ? count : '' %>
              </td>
            <% } %>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="panel">
    <h2>Latest Scans</h2>
    <% if (scans.length === 0) { %>
      <p class="sub" style="margin:0;">No scans recorded yet.</p>
    <% } else { %>
    <div style="overflow-x:auto;">
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Source</th>
            <th>Device</th>
            <th>OS</th>
            <th>Language</th>
            <th>Location</th>
          </tr>
        </thead>
        <tbody>
          <% scans.forEach(s => { %>
          <tr>
            <td data-label="Date"><%= new Date(s.scanned_at).toLocaleString('en-US', { timeZone: 'Asia/Makassar', dateStyle: 'medium', timeStyle: 'short' }) %></td>
            <td data-label="Source"><%= s.source === 'nfc' ? 'NFC' : (s.source === 'qr' ? 'QR Code' : '—') %></td>
            <td data-label="Device"><%= s.device_vendor || '—' %></td>
            <td data-label="OS"><%= s.os_name || '—' %></td>
            <td data-label="Language"><%= s.browser_lang || '—' %></td>
            <td data-label="Location"><%= s.city ? s.city + ', ' + s.country : (s.country || '—') %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    
    <% if (totalPages > 1) { %>
    <div style="margin-top: 14px; display: flex; gap: 8px; align-items: center;">
      <% if (page > 1) { %>
        <a href="?page=<%= page - 1 %>&filter=<%= currentFilter %>" class="btn secondary" style="padding: 4px 10px; font-size: 12px;">← Prev</a>
      <% } %>
      <span style="font-size: 13px; color: var(--ink); padding: 4px;">Page <%= page %> of <%= totalPages %></span>
      <% if (page < totalPages) { %>
        <a href="?page=<%= page + 1 %>&filter=<%= currentFilter %>" class="btn secondary" style="padding: 4px 10px; font-size: 12px;">Next →</a>
      <% } %>
    </div>
    <% } %>
    
    <% } %>
  </div>

  <div class="panel" style="background: rgba(127,191,143,0.1); border-color: var(--good); text-align: center;">
    <h2 style="color: var(--good); margin-bottom: 8px;">Need help?</h2>
    <p class="sub" style="margin-bottom: 14px; color: var(--ink);">Any questions about your cards or need modifications?</p>
    <a href="https://wa.me/6281558509613" target="_blank" class="btn" style="background: #25D366; color: white;">Contact WhatsApp Support</a>
  </div>

</div>
<!-- Client bottom padding for consistency -->
<style>@media (max-width: 700px) { body { padding-bottom: 20px; } }</style>

<script>
  Chart.defaults.color = '#9a9ba3';
  Chart.defaults.borderColor = '#33353f';
  
  const ctx = document.getElementById('scansChart').getContext('2d');
  const chartData = <%- JSON.stringify(chartData) %>;
  
  const labels = chartData.map(d => d.date);
  const nfcData = chartData.map(d => d.nfc);
  const qrData = chartData.map(d => d.qr);

  new Chart(ctx, {
    type: 'line',
    data: {
      labels: labels,
      datasets: [
        {
          label: 'NFC Scans',
          data: nfcData,
          borderColor: '#e8935c', // copper-bright
          backgroundColor: 'rgba(232, 147, 92, 0.1)',
          tension: 0.3,
          fill: true
        },
        {
          label: 'QR Scans',
          data: qrData,
          borderColor: '#7fbf8f', // good
          backgroundColor: 'rgba(127, 191, 143, 0.1)',
          tension: 0.3,
          fill: true
        }
      ]
    },
    options: {
      responsive: true,
      interaction: {
        mode: 'index',
        intersect: false,
      },
      plugins: {
        legend: { position: 'top' }
      },
      scales: {
        y: { beginAtZero: true, ticks: { stepSize: 1 } }
      }
    }
  });
</script>
</body>
</html>
