<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Card <%= tag.code %> — NFC Review Tracker</title>
<link rel="stylesheet" href="/style.css">
<!-- Chart.js for graphs -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
<div class="wrap">
  <div class="top-nav">
    <div class="links"><a href="/admin">← Back</a></div>
  </div>

  <div class="panel">
    <div class="eyebrow"><span class="dot"></span>CARD DETAILS</div>
    <div style="display:flex; justify-content:space-between; align-items:flex-start;">
      <h1><%= tag.code %></h1>
      <form method="POST" action="/admin/tags/<%= tag.code %>/delete" onsubmit="return confirm('Are you sure you want to delete this card?');">
        <button class="btn danger" type="submit" style="padding: 6px 12px; font-size: 12px;">Delete</button>
      </form>
    </div>

    <form method="POST" action="/admin/tags/<%= tag.code %>">
      <label for="business_name">Business Name</label>
      <input type="text" id="business_name" name="business_name" value="<%= tag.business_name || '' %>">

      <!-- Google Place ID Assistant -->
      <div style="background: rgba(201,123,74,0.05); border: 1px dashed var(--copper); padding: 12px; border-radius: 7px; margin-bottom: 14px;">
        <label style="color: var(--copper); margin-bottom: 4px;">Google Review Link Generator</label>
        <p style="font-size: 11px; color: var(--ink-dim); margin-top: 0; margin-bottom: 8px;">
          Find your Place ID <a href="https://developers.google.com/maps/documentation/places/web-service/place-id" target="_blank" style="color: var(--copper); text-decoration: underline;">here</a>, paste it below, and click Generate.
        </p>
        <div class="row" style="margin-bottom:0;">
          <input type="text" id="google_place_id" name="google_place_id" value="<%= tag.google_place_id || '' %>" placeholder="ChIJ..." style="margin-bottom:0; flex:1;">
          <button type="button" class="btn secondary" onclick="generateUrl()">Generate URL</button>
        </div>
      </div>

      <label for="review_url">Google Review URL</label>
      <input type="text" id="review_url" name="review_url" value="<%= tag.review_url || '' %>">

      <label for="price_paid">Price Paid (IDR)</label>
      <input type="number" id="price_paid" name="price_paid" value="<%= tag.price_paid || '' %>">

      <label for="client_whatsapp">Client WhatsApp Number</label>
      <input type="text" id="client_whatsapp" name="client_whatsapp" value="<%= tag.client_whatsapp || '' %>" placeholder="+628123456789">

      <label for="notes">Notes</label>
      <textarea id="notes" name="notes" rows="3"><%= tag.notes || '' %></textarea>

      <div class="checkbox-row">
        <input type="checkbox" id="active" name="active" <%= tag.active ? 'checked' : '' %>>
        <label for="active" style="margin:0;">Active Card (sold and functional)</label>
      </div>

      <button class="btn" type="submit">Save</button>
    </form>
  </div>

  <div class="panel">
    <h2>Client Portal</h2>
    <p class="sub" style="margin-bottom:12px;">This space allows the client to view their statistics.</p>
    
    <label>Access URL for the client</label>
    <% const clientUrl = qrUrl.split('/r/')[0] + '/client/' + tag.code; %>
    <div style="display:flex; gap:8px; margin-bottom:14px;">
      <input type="text" readonly value="<%= clientUrl %>" onclick="this.select()" style="margin-bottom:0;">
      <a href="<%= clientUrl %>" target="_blank" class="btn secondary">Test</a>
    </div>

    <form method="POST" action="/admin/tags/<%= tag.code %>">
      <input type="hidden" name="business_name" value="<%= tag.business_name || '' %>">
      <input type="hidden" name="review_url" value="<%= tag.review_url || '' %>">
      <input type="hidden" name="price_paid" value="<%= tag.price_paid || '' %>">
      <input type="hidden" name="client_whatsapp" value="<%= tag.client_whatsapp || '' %>">
      <input type="hidden" name="notes" value="<%= tag.notes || '' %>">
      <input type="hidden" name="google_place_id" value="<%= tag.google_place_id || '' %>">
      <% if (tag.active) { %><input type="hidden" name="active" value="on"><% } %>

      <label for="client_password">Client Password</label>
      <div class="row" style="margin-bottom:0;">
        <input type="text" id="client_password" name="client_password" value="<%= tag.client_password || '' %>" placeholder="Leave empty to disable access" style="margin-bottom:0; flex:1;">
        <button class="btn secondary" type="submit">Save Password</button>
      </div>
    </form>
  </div>

  <% if (reviewHistory && reviewHistory.length > 0) { 
       const latest = reviewHistory[reviewHistory.length - 1];
       const first = reviewHistory[0];
       const rating = parseFloat(latest.rating).toFixed(1);
       const reviewCount = latest.user_ratings_total;
       
       const reviewGrowth = reviewCount - first.user_ratings_total;
       const ratingGrowth = (latest.rating - first.rating).toFixed(1);
  %>
  <div class="panel" style="background: linear-gradient(145deg, rgba(232, 147, 92, 0.1), rgba(20, 21, 26, 0.8)); border-color: var(--copper); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;">
    <div>
      <h2 style="color: var(--copper-bright); margin-bottom: 4px; display: flex; align-items: center; gap: 8px;">
        Google Reviews <span style="font-size: 11px; padding: 2px 6px; background: var(--copper); color: #000; border-radius: 4px; font-weight: 600;">LIVE</span>
      </h2>
      <div style="font-size: 32px; font-weight: bold; color: white; display: flex; align-items: center; gap: 8px;">
        <%= rating %> <div style="color: #FFD700; font-size: 24px;">★★★★★</div>
      </div>
      <div style="color: var(--ink-dim); font-size: 13px;">Based on <%= reviewCount %> authentic reviews</div>
    </div>
    
    <% if (reviewGrowth > 0 || ratingGrowth > 0) { %>
    <div style="background: rgba(127,191,143,0.1); border: 1px solid var(--good); padding: 12px 16px; border-radius: 8px; flex: 1; min-width: 200px;">
      <div style="font-size: 13px; color: var(--good); margin-bottom: 4px;">🚀 Impact since activation</div>
      <div style="font-size: 15px; color: white;">
        <% if (reviewGrowth > 0) { %>+<b><%= reviewGrowth %></b> new reviews<% } %>
        <% if (ratingGrowth > 0 && reviewGrowth > 0) { %> & <% } %>
        <% if (ratingGrowth > 0) { %>rating went up by <b>+<%= ratingGrowth %></b><% } %>
      </div>
    </div>
    <% } %>
  </div>
  <% } %>

  <div class="panel">
    <h2>Scan Analytics</h2>
    <canvas id="scansChart" width="400" height="150"></canvas>
  </div>

  <div class="panel">
    <h2>Detailed Statistics</h2>
    <div class="stats-grid" style="grid-template-columns: repeat(2, 1fr);">
      <div class="stat">
        <div class="label" style="margin-top:0; margin-bottom:8px;">Top OS</div>
        <% if (osStats && osStats.length > 0) { %>
          <% osStats.forEach(os => { %>
            <div style="display:flex; justify-content:space-between; font-size:13px; margin-bottom:4px;">
              <span><%= os.os_name %></span>
              <span style="color:var(--copper-bright); font-family:'JetBrains Mono',monospace;"><%= os.count %></span>
            </div>
          <% }) %>
        <% } else { %>
          <div style="font-size:13px; color:var(--ink-faint);">No data</div>
        <% } %>
      </div>
      <div class="stat">
        <div class="label" style="margin-top:0; margin-bottom:8px;">Top Languages</div>
        <% if (langStats && langStats.length > 0) { %>
          <% langStats.forEach(lang => { %>
            <div style="display:flex; justify-content:space-between; font-size:13px; margin-bottom:4px;">
              <span><%= lang.browser_lang %></span>
              <span style="color:var(--copper-bright); font-family:'JetBrains Mono',monospace;"><%= lang.count %></span>
            </div>
          <% }) %>
        <% } else { %>
          <div style="font-size:13px; color:var(--ink-faint);">No data</div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="panel">
    <h2>Hourly Heatmap</h2>
    <p class="sub" style="margin-bottom:12px;">Concentration of scans by day and hour</p>
    <div style="overflow-x:auto;">
      <table class="heatmap-table" style="min-width: 600px; border-collapse: separate; border-spacing: 2px;">
        <thead>
          <tr>
            <th style="width: 35px; border: none; background: transparent;"></th>
            <% for (let h = 0; h < 24; h++) { %>
              <th style="font-size: 9px; font-weight: normal; color: var(--ink-faint); border: none; background: transparent; text-align: center; padding: 2px;"><%= h %>h</th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% const days = ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun']; %>
          <% for (let d = 0; d < 7; d++) { %>
          <tr>
            <td style="font-size: 11px; color: var(--ink-dim); border: none; background: transparent; text-align: right; padding-right: 6px;"><%= days[d] %></td>
            <% for (let h = 0; h < 24; h++) { %>
              <% 
                const count = heatmapData[d][h]; 
                const intensity = maxHeat > 0 ? (count / maxHeat) : 0;
                // on admin we use copper theme
                const bgColor = count > 0 ? `rgba(232, 147, 92, ${Math.max(0.15, intensity)})` : 'rgba(255,255,255,0.02)';
                const textColor = count > 0 ? (intensity > 0.6 ? '#14151a' : 'var(--copper-bright)') : 'transparent';
              %>
              <td style="background: <%- bgColor %>; border: none; text-align: center; font-size: 10px; font-weight: 600; color: <%- textColor %>; border-radius: 3px; height: 22px; cursor: default;" title="<%= days[d] %> <%= h %>h: <%= count %> scans">
                <%= count > 0 ? count : '' %>
              </td>
            <% } %>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="panel">
    <h2>Recent Scans (Detailed)</h2>
    <% if (scans.length === 0) { %>
      <p class="sub" style="margin:0;">No scans recorded yet.</p>
    <% } else { %>
    <div style="overflow-x:auto;">
      <table>
        <thead>
          <tr>
            <th>Date</th>
            <th>Source</th>
            <th>Device</th>
            <th>OS</th>
            <th>Language</th>
            <th>Location</th>
            <th>IP Address</th>
          </tr>
        </thead>
        <tbody>
          <% scans.forEach(s => { %>
          <tr>
            <td data-label="Date"><%= new Date(s.scanned_at).toLocaleString('en-US', { timeZone: 'Asia/Makassar', dateStyle: 'short', timeStyle: 'short' }) %></td>
            <td data-label="Source"><%= s.source === 'nfc' ? 'NFC' : (s.source === 'qr' ? 'QR Code' : '—') %></td>
            <td data-label="Device"><%= s.device_vendor || '—' %></td>
            <td data-label="OS"><%= s.os_name || '—' %></td>
            <td data-label="Language"><%= s.browser_lang || '—' %></td>
            <td data-label="Location"><%= s.city ? s.city + ', ' + s.country : (s.country || '—') %></td>
            <td data-label="IP"><%= s.ip_address || '—' %></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    
    <% if (totalPages > 1) { %>
    <div style="margin-top: 14px; display: flex; gap: 8px; align-items: center;">
      <% if (page > 1) { %>
        <a href="?page=<%= page - 1 %>" class="btn secondary" style="padding: 4px 10px; font-size: 12px;">← Prev</a>
      <% } %>
      <span style="font-size: 13px; color: var(--ink); padding: 4px;">Page <%= page %> of <%= totalPages %></span>
      <% if (page < totalPages) { %>
        <a href="?page=<%= page + 1 %>" class="btn secondary" style="padding: 4px 10px; font-size: 12px;">Next →</a>
      <% } %>
    </div>
    <% } %>
    <% } %>
  </div>

  <div class="panel">
    <h2>URLs to Program</h2>
    <p class="sub" style="margin-bottom:12px;">
      Write the NFC URL using NFC Tools. The QR below is ready to print.
    </p>

    <label>NFC URL</label>
    <div style="display:flex; gap:8px; margin-bottom:14px;">
      <input type="text" readonly value="<%= nfcUrl %>" onclick="this.select()" style="margin-bottom:0;">
      <a href="<%= nfcUrl %>" target="_blank" class="btn secondary">Test</a>
    </div>

    <label>QR URL</label>
    <div style="display:flex; gap:8px; margin-bottom:14px;">
      <input type="text" readonly value="<%= qrUrl %>" onclick="this.select()" style="margin-bottom:0;">
      <a href="<%= qrUrl %>" target="_blank" class="btn secondary">Test</a>
    </div>

    <div class="qr-google-frame" id="qr-container">
      <!-- QR code injected by JS -->
    </div>
    <div style="margin-top:10px;">
      <button onclick="downloadQR()" class="btn secondary" style="font-size:12px; padding:6px 12px;">Download QR</button>
    </div>
  </div>

  <div class="panel" style="background: rgba(217,123,123,0.05); border-color: var(--bad);">
    <h2 style="color: var(--bad); margin-bottom: 8px;">🛠️ Developer & Testing Tools</h2>
    <p class="sub" style="margin-bottom: 14px;">These tools are only visible to the admin. Use them to manage demo data.</p>
    
    <div style="display:flex; gap:12px; flex-wrap:wrap;">
      <form method="POST" action="/admin/tags/<%= tag.code %>/fetch-google">
        <button class="btn secondary" type="submit">🔄 Fetch Google API</button>
      </form>

      <form method="POST" action="/admin/tags/<%= tag.code %>/mockup" onsubmit="return confirm('Generate 50-100 fake scans (Bali locations) for demonstration?');">
        <button class="btn secondary" type="submit">🪄 Generate Mockup Data</button>
      </form>
      
      <form method="POST" action="/admin/tags/<%= tag.code %>/reset" onsubmit="return confirm('Are you sure you want to permanently delete all scans for this card?');">
        <button class="btn danger" type="submit">🧹 Reset All Stats</button>
      </form>
    </div>
  </div>

</div>

<!-- QR Code Styling Library -->
<script src="https://unpkg.com/qr-code-styling@1.5.0/lib/qr-code-styling.js"></script>
<!-- html2canvas pour capturer le cadre Google complet en PNG -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<script>
const qrCode = new QRCodeStyling({
  width: 1000,
  height: 1000,
  data: "<%= qrUrl %>",
  margin: 10,
  dotsOptions: { type: "rounded", color: "#000000" },
  cornersSquareOptions: { type: "extra-rounded", color: "#000000" },
  cornersDotOptions: { type: "dot", color: "#000000" },
  backgroundOptions: { color: "transparent" } // Fond transparent pour le QR lui-même
});
qrCode.append(document.getElementById("qr-container"));

function downloadQR() {
  const container = document.getElementById("qr-container");
  // On capture le cadre entier (bordure + QR) en très haute qualité (scale: 10)
  html2canvas(container, { backgroundColor: null, scale: 10 }).then(canvas => {
    const link = document.createElement('a');
    link.download = "QR_<%= tag.code %>.png";
    link.href = canvas.toDataURL("image/png");
    link.click();
  });
}
</script>

<script>
function generateUrl() {
  const placeId = document.getElementById('google_place_id').value.trim();
  if (placeId) {
    document.getElementById('review_url').value = `https://search.google.com/local/writereview?placeid=${placeId}`;
  }
}
</script>

<script>
  Chart.defaults.color = '#9a9ba3';
  Chart.defaults.borderColor = '#33353f';
  
  const ctx = document.getElementById('scansChart').getContext('2d');
  const chartData = <%- JSON.stringify(chartData || []) %>;
  
  const labels = chartData.map(d => d.date);
  const nfcData = chartData.map(d => d.nfc);
  const qrData = chartData.map(d => d.qr);

  new Chart(ctx, {
    type: 'line',
    data: {
      labels: labels,
      datasets: [
        {
          label: 'NFC Scans',
          data: nfcData,
          borderColor: '#e8935c', // copper-bright
          backgroundColor: 'rgba(232, 147, 92, 0.1)',
          tension: 0.3,
          fill: true
        },
        {
          label: 'QR Scans',
          data: qrData,
          borderColor: '#7fbf8f', // good
          backgroundColor: 'rgba(127, 191, 143, 0.1)',
          tension: 0.3,
          fill: true
        }
      ]
    },
    options: {
      responsive: true,
      interaction: {
        mode: 'index',
        intersect: false,
      },
      plugins: {
        legend: { position: 'top' }
      },
      scales: {
        y: { beginAtZero: true, ticks: { stepSize: 1 } }
      }
    }
  });
</script>

<%- include('partials/bottom-nav', { navActive: 'none' }) %>
</body>
</html>
